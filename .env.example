# ========================================
# Profile: core (offline MP4, bez ROS2)
# ========================================
# Ścieżka do pliku MP4 używanego przez profil `core`.
INPUT_MP4_PATH=/workspace/robot_perception/data/sample.mp4

# ========================================
# Profile: ros-hw (ROS2 + mostki + /dev)
# ========================================
# Dystrybucja ROS2 dostępna w kontenerze.
ROS_DISTRO=humble

# Urządzenia hosta mapowane do kontenera.
RGB_CAMERA_DEVICE=/dev/video0
DEPTH_CAMERA_DEVICE=/dev/video1

# Nazwy topiców RTAB-Map przekazywane do runtime.
RTABMAP_ODOM_TOPIC=/rtabmap/odom_info
RTABMAP_MAPDATA_TOPIC=/rtabmap/mapData
RTABMAP_LOCALIZATION_TOPIC=/rtabmap/info
